---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EmailLink from "@/components/EmailLink.astro";
---

<BaseLayout title="Privacy Policy" description="Read how Offline Maps Guide addresses accounts, analytics, advertising cookies, external links, and privacy questions on this static website." canonical="/privacy/">
  <section class="article-hero">
    <div class="container">
      <p class="eyebrow">Policy</p>
      <h1>Privacy Policy</h1>
    </div>
  </section>
  <section class="section">
    <div class="container article">
      <p>
        Offline Maps Guide is a static content website. We do not require reader accounts or collect personal information through this site by default.
      </p>
      <h2>Analytics and advertising</h2>
      <p>
        Hosting, analytics, and security providers may process IP addresses, browser or device information, requested pages, timestamps, and referral data to operate, protect, and improve the site.
      </p>
      <h2>Advertising cookies</h2>
      <p>Offline Maps Guide may use third-party advertising services, including Google AdSense. Third-party vendors, including Google, may use cookies, web beacons, IP addresses, or similar identifiers to serve and measure ads based on a visitor's prior visits to this website or other websites.</p>
      <p>You can control or opt out of personalized Google advertising through <a href="https://adssettings.google.com/">Google Ads Settings</a>. Additional industry opt-out choices are available at <a href="https://www.aboutads.info/choices/">aboutads.info</a>.</p>
      <h2>External links</h2>
      <p>
        Articles may link to app stores, official documentation, travel providers, or affiliate partners. Those sites have their own privacy practices.
      </p>
      <h2>Contact</h2>
      <p>Privacy questions can be sent to <EmailLink />.</p>
      <p>Last updated July 11, 2026.</p>
    </div>
  </section>
</BaseLayout>
