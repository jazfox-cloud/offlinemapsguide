---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Policy" description="Privacy policy for Offline Maps Guide." canonical="/privacy/">
  <section class="article-hero">
    <div class="container">
      <p class="eyebrow">Policy</p>
      <h1>Privacy Policy</h1>
    </div>
  </section>
  <section class="section">
    <div class="container article">
      <p>
        Offline Maps Guide is a static content website. We do not require reader accounts or collect personal information through this site by default.
      </p>
      <h2>Analytics and advertising</h2>
      <p>
        The site may add privacy-conscious analytics or advertising in the future. If that changes, this page should be updated with the services used and how readers can manage their preferences.
      </p>
      <h2>External links</h2>
      <p>
        Articles may link to app stores, official documentation, travel providers, or affiliate partners. Those sites have their own privacy practices.
      </p>
    </div>
  </section>
</BaseLayout>
