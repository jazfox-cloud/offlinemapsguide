---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EmailLink from "@/components/EmailLink.astro";
---
<BaseLayout title="Contact" description="Contact Offline Maps Guide to report corrections, app feature changes, source suggestions, privacy requests, or accessibility issues." canonical="/contact/">
  <section class="article-hero"><div class="container"><p class="eyebrow">Contact</p><h1>Contact Offline Maps Guide</h1></div></section>
  <section class="section"><div class="container article"><p>Email <EmailLink /> for corrections, app feature changes, source suggestions, privacy requests, or accessibility reports.</p><p>For a correction, include the page URL, device platform, app version when relevant, and an official document or reproducible test. We cannot provide account support for third-party map or travel apps.</p></div></section>
</BaseLayout>
