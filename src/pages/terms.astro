---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Terms of Use" description="Read the Offline Maps Guide terms covering informational travel content, navigation and safety limitations, and changes to published guides." canonical="/terms/">
  <section class="article-hero">
    <div class="container">
      <p class="eyebrow">Policy</p>
      <h1>Terms of Use</h1>
    </div>
  </section>
  <section class="section">
    <div class="container article">
      <p>
        Offline Maps Guide provides informational content for travel preparation. Navigation, safety, visa, transport, and emergency decisions should be verified with current official sources.
      </p>
      <h2>No safety guarantee</h2>
      <p>
        Offline maps can fail because of outdated data, device issues, closures, terrain, battery drain, or local conditions. Use appropriate safety planning for your destination and activity.
      </p>
      <h2>Content changes</h2>
      <p>
        We may update, remove, or reorganize content as apps, routes, and travel conditions change.
      </p>
    </div>
  </section>
</BaseLayout>
