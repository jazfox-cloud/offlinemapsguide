---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Editorial Policy" description="Read the Offline Maps Guide standards for sourcing, practical travel guidance, affiliate independence, corrections, and content updates." canonical="/editorial-policy/">
  <section class="article-hero">
    <div class="container">
      <p class="eyebrow">Policy</p>
      <h1>Editorial Policy</h1>
    </div>
  </section>
  <section class="section">
    <div class="container article">
      <p>
        Offline Maps Guide publishes practical travel navigation content based on official documentation, product behavior, public community feedback, and clearly stated limitations.
      </p>
      <h2>Affiliate disclosure</h2>
      <p>
        Some future pages may include affiliate links for eSIMs, travel tools, insurance, or privacy products. Affiliate relationships must be disclosed near the recommendation and must not override practical trip-preparation guidance.
      </p>
      <h2>Corrections</h2>
      <p>
        Offline map apps, data policies, and travel infrastructure change. Articles should be updated when official documentation or reliable community evidence shows that a recommendation is outdated.
      </p>
    </div>
  </section>
</BaseLayout>
